{
  "name": "browser-api",
  "version": "0.1.0",
  "description": "Headless browser (Playwright) exposed over an HTTP API, with persistent login sessions. Built to run on Railway.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@fastify/sensible": "^6.0.2",
    "@mozilla/readability": "^0.6.0",
    "fastify": "^5.2.0",
    "playwright": "1.61.1",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/turndown": "^5.0.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
