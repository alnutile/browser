# Copy to .env for local dev. On Railway, set these in the service Variables tab.

# REQUIRED. Shared secret callers send as: Authorization: Bearer <API_TOKEN>
# Generate one, e.g.:  openssl rand -hex 32
API_TOKEN=change-me

# Where persistent browser profiles + session state live.
# On Railway, mount a Volume and point this at its mount path (e.g. /data).
DATA_DIR=./data

# Run Chromium headless (true) or headful for local debugging (false).
HEADLESS=true

# Optional tuning.
PORT=3000
SESSION_IDLE_MS=600000
DEFAULT_TIMEOUT_MS=30000
MAX_SESSIONS=5
LOG_LEVEL=info

# Bypass page Content Security Policy so the markdown action can inject the
# Readability extractor on CSP-strict sites (GitHub, Twitter, many SaaS apps).
# Set to false to enforce site CSP (markdown then falls back to whole-body).
BYPASS_CSP=true

# Natural-language endpoint (POST /sessions/:id/prompt). Send a plain-English
# task and Claude drives the browser via tool use until it's done.
# ANTHROPIC_API_KEY is only needed for this endpoint; every other route works
# without it. Get a key at https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-8
# AGENT_EFFORT=high              # low | medium | high | xhigh | max
# AGENT_MAX_STEPS=40             # max agent<->browser round trips per call
# AGENT_MAX_TOKENS=16000         # max output tokens per model turn
# AGENT_MAX_TOOL_RESULT_CHARS=20000  # truncate big page dumps fed to the model
