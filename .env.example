# Copy to .env for local dev. On Railway, set these in the service Variables tab.

# REQUIRED. Shared secret callers send as: Authorization: Bearer <API_TOKEN>
# Generate one, e.g.:  openssl rand -hex 32
API_TOKEN=change-me

# Where persistent browser profiles + session state live.
# On Railway, mount a Volume and point this at its mount path (e.g. /data).
DATA_DIR=./data

# Run Chromium headless (true) or headful for local debugging (false).
HEADLESS=true

# Optional tuning.
PORT=3000
SESSION_IDLE_MS=600000
DEFAULT_TIMEOUT_MS=30000
MAX_SESSIONS=5
LOG_LEVEL=info
